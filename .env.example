# ── REQUIRED ─────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# PostgreSQL connection string
# Heroku:  heroku addons:create heroku-postgresql  (auto-sets DATABASE_URL)
# Railway: add a PostgreSQL plugin  (auto-sets DATABASE_URL)
# Local:   postgresql://user:password@localhost:5432/hotel85
DATABASE_URL=postgresql://user:password@localhost:5432/hotel85

# ── ACCESS CONTROL ────────────────────────────────────────────────────
# Comma-separated Telegram user IDs that have admin access
# Find your ID by messaging @userinfobot on Telegram
# Leave blank to auto-promote the first /start user as admin
ADMIN_IDS=123456789,987654321

# ── OPTIONAL ──────────────────────────────────────────────────────────
# Chat ID (or group ID) that receives the automated daily report
# Leave blank to disable scheduled reports
REPORT_CHAT_ID=

# Hotel name shown in reports
HOTEL_NAME=Hotel 85

# Time for daily automated report (24-hour HH:MM)
DAILY_REPORT_TIME=23:00

# Timezone for scheduled report (IANA format)
TIMEZONE=Africa/Lagos

# Default low-stock alert threshold (units)
LOW_STOCK_DEFAULT=5
